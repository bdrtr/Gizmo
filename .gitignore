# Rust / Cargo
/target
# Cargo.lock IS committed: this workspace ships binaries (demo, server, cradle,
# demo-web) and a browser build verified against a specific dependency graph, so
# CI and contributors must resolve the same versions (built with `--locked`).

# OS artifacts
.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Binaries
*.exe
*.dll
*.so
*.dylib

# Temporary files & editors
*.log
*.tmp
*.swp
*.swo
.*.sw?
*~
.vscode/
.idea/
.aider*
.claude/

# Scratch / one-off files
scratch/
scratch.rs
*.py

# Runtime / editor state
editor_prefs.toml
.play_backup.scene

# Large assets (tracked via Git LFS or downloaded separately)
*.glb
assets/*.crdownload

# Environment variables
.env
.env.local
.env.development
.env.production

# wasm-bindgen output (demo-web packaging artifact; rebuilt from source)
demo-web/pkg/

# Rustfmt / rustc backups & internal-compiler-error dumps
**/*.rs.bk
rustc-ice-*.txt

# Merge / patch leftovers
*.orig
*.rej

# Profiling & coverage output (cargo-flamegraph, perf, LLVM-cov, cargo timings)
flamegraph.svg
perf.data
perf.data.old
*.profraw
*.profdata
lcov.info
cargo-timing-*.html
tarpaulin-report.html

# Nix — flake.nix / flake.lock ARE committed; these are local build state only
.direnv/
/result
/result-*

# Python bytecode (scratch *.py is already ignored above)
__pycache__/
*.pyc
